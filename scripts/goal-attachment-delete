#!/usr/bin/env ruby
# frozen_string_literal: true

#
# scripts/goal-attachment-delete - Delete an attachment from a goal
#
# Usage: goal-attachment-delete <goal_id> <attachment_id>
#
# Output: JSON {"ok": true}
# Exit code: 0 on success, 1 on failure
#

require 'json'
require 'net/http'
require 'optparse'

RALPH_PLANS_URL = ENV.fetch('RALPH_PLANS_URL', 'http://ralph-plans.localhost:8000')

def main
  OptionParser.new do |opts|
    opts.banner = <<~HELP
      Usage: goal-attachment-delete <goal_id> <attachment_id>

      Delete an attachment from a pipeline goal.

      Arguments:
        goal_id        Goal ID (required)
        attachment_id  Attachment ID (required)

      Output:
        JSON {"ok": true}

      Examples:
        goal-attachment-delete 42 7
    HELP
  end.parse!

  goal_id = ARGV[0]&.to_i
  attachment_id = ARGV[1]&.to_i

  unless goal_id && goal_id > 0
    puts JSON.generate(ok: false, error: 'goal_id is required')
    exit 1
  end

  unless attachment_id && attachment_id > 0
    puts JSON.generate(ok: false, error: 'attachment_id is required')
    exit 1
  end

  uri = URI("#{RALPH_PLANS_URL}/goals/#{goal_id}/attachments/#{attachment_id}")
  req = Net::HTTP::Delete.new(uri)
  resp = Net::HTTP.start(uri.hostname, uri.port) { |http| http.request(req) }
  result = JSON.parse(resp.body)

  puts JSON.generate(result)
  exit(result['ok'] ? 0 : 1)
rescue Errno::ECONNREFUSED
  puts JSON.generate(ok: false, error: "cannot connect to ralph-plans at #{RALPH_PLANS_URL}")
  exit 1
end

if __FILE__ == $PROGRAM_NAME
  begin
    main
  rescue Interrupt
    exit 130
  end
end
