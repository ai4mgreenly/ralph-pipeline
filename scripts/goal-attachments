#!/usr/bin/env ruby
# frozen_string_literal: true

#
# scripts/goal-attachments - List attachments for a goal
#
# Usage: goal-attachments <goal_id>
#
# Output: JSON {"ok": true, "items": [...]}
# Exit code: 0 on success, 1 on failure
#

require 'json'
require 'net/http'
require 'optparse'

RALPH_PLANS_BASE = "#{ENV.fetch('RALPH_PLANS_URL')}/api/plans"

def main
  OptionParser.new do |opts|
    opts.banner = <<~HELP
      Usage: goal-attachments <goal_id>

      List attachments for a pipeline goal.

      Arguments:
        goal_id    Goal ID (required)

      Output:
        JSON {"ok": true, "items": [...]}
        Each item: {id, goal_id, name, created_at} (body excluded)

      Examples:
        goal-attachments 42
        goal-attachments 42 | jq '.items[].name'
    HELP
  end.parse!

  goal_id = ARGV[0]&.to_i

  unless goal_id && goal_id > 0
    puts JSON.generate(ok: false, error: 'goal_id is required')
    exit 1
  end

  uri = URI("#{RALPH_PLANS_BASE}/goals/#{goal_id}/attachments")
  resp = Net::HTTP.get_response(uri)
  result = JSON.parse(resp.body)

  puts JSON.generate(result)
  exit(result['ok'] ? 0 : 1)
rescue Errno::ECONNREFUSED
  puts JSON.generate(ok: false, error: "cannot connect to ralph-plans at #{RALPH_PLANS_BASE}")
  exit 1
end

if __FILE__ == $PROGRAM_NAME
  begin
    main
  rescue Interrupt
    exit 130
  end
end
