#!/usr/bin/env ruby
# frozen_string_literal: true

#
# scripts/goal-create - Create a pipeline goal via ralph-plans API
#
# Reads goal body from stdin. Metadata via flags.
#
# Usage: goal-create --title "..." --org ORG --repo REPO < body.md
#
# Output: JSON {"ok": true, "id": <goal-id>}
# Exit code: 0 on success, 1 on failure
#

require 'json'
require 'net/http'
require 'optparse'

RALPH_PLANS_URL = ENV.fetch('RALPH_PLANS_URL', 'http://ralph-plans.localhost:8000')

def derive_org_repo_from_remote
  url = `git remote get-url origin 2>/dev/null`.strip
  return [nil, nil] if url.empty?

  # Local bare repo: /mnt/store/git/<org>/<repo>
  if url.start_with?('/')
    parts = url.split('/')
    return [parts[-2], parts[-1]] if parts.length >= 2
  end

  # GitHub SSH URL: git@github.com:<org>/<repo>.git
  if (m = url.match(/git@[^:]+:([^\/]+)\/(.+?)(?:\.git)?$/))
    return [m[1], m[2]]
  end

  # HTTPS URL: https://github.com/<org>/<repo>.git
  if (m = url.match(%r{https?://[^/]+/([^/]+)/(.+?)(?:\.git)?$}))
    return [m[1], m[2]]
  end

  [nil, nil]
end

def main
  title = nil
  org = nil
  repo = nil
  model = nil
  reasoning = nil

  OptionParser.new do |opts|
    opts.banner = <<~HELP
      Usage: goal-create --title "..." [--org ORG] [--repo REPO] [--model MODEL] [--reasoning LEVEL] < body.md

      Create a pipeline goal. Body is read from stdin.

      org and repo are auto-derived from git remote get-url origin when omitted.
      Use --org/--repo only to target a different repo than the current directory.

      Flags:
        --title "..."       Goal title (required)
        --org ORG           Organization (optional; auto-derived from remote origin)
        --repo REPO         Repository name (optional; auto-derived from remote origin)
        --model MODEL       Model to use: haiku, sonnet, opus (optional)
        --reasoning LEVEL   Reasoning level: none, low, med, high (optional)

      Output:
        JSON {"ok": true, "id": <goal-id>}

      Examples:
        echo "## Objective\\nDo the thing" | goal-create --title "Add X"
        echo "## Objective\\nDo the thing" | goal-create --title "Add X" --model opus --reasoning high
        echo "## Objective\\nDo the thing" | goal-create --title "Add X" --org mgreenly --repo other-repo
    HELP

    opts.on('--title=TITLE', 'Goal title') { |t| title = t }
    opts.on('--org=ORG', 'Organization (optional; auto-derived from remote origin)') { |o| org = o }
    opts.on('--repo=REPO', 'Repository name (optional; auto-derived from remote origin)') { |r| repo = r }
    opts.on('--model=MODEL', 'Model (haiku, sonnet, opus)') { |m| model = m }
    opts.on('--reasoning=LEVEL', 'Reasoning level (none, low, med, high)') { |r| reasoning = r }
  end.parse!

  unless title
    puts JSON.generate(ok: false, error: '--title is required')
    exit 1
  end

  # Auto-derive org/repo from remote origin if not provided
  if org.nil? || repo.nil?
    derived_org, derived_repo = derive_org_repo_from_remote
    org ||= derived_org
    repo ||= derived_repo
  end

  unless org
    puts JSON.generate(ok: false, error: '--org not provided and could not be derived from git remote origin')
    exit 1
  end

  unless repo
    puts JSON.generate(ok: false, error: '--repo not provided and could not be derived from git remote origin')
    exit 1
  end

  # Validate model if provided
  if model
    valid_models = %w[haiku sonnet opus]
    unless valid_models.include?(model)
      puts JSON.generate(ok: false, error: "--model must be one of: #{valid_models.join(', ')}")
      exit 1
    end
  end

  # Validate reasoning if provided
  if reasoning
    valid_levels = %w[none low med high]
    unless valid_levels.include?(reasoning)
      puts JSON.generate(ok: false, error: "--reasoning must be one of: #{valid_levels.join(', ')}")
      exit 1
    end
  end

  # Read body from stdin
  if $stdin.tty?
    puts JSON.generate(ok: false, error: 'body must be provided on stdin')
    exit 1
  end

  body = $stdin.read.strip

  if body.empty?
    puts JSON.generate(ok: false, error: 'body is empty')
    exit 1
  end

  # POST to ralph-plans API
  uri = URI("#{RALPH_PLANS_URL}/goals")
  payload = { org: org, repo: repo, title: title, body: body }
  payload[:model] = model if model
  payload[:reasoning] = reasoning if reasoning

  resp = Net::HTTP.post(uri, JSON.generate(payload), 'Content-Type' => 'application/json')
  result = JSON.parse(resp.body)

  puts JSON.generate(result)
  exit(result['ok'] ? 0 : 1)
rescue Errno::ECONNREFUSED
  puts JSON.generate(ok: false, error: "cannot connect to ralph-plans at #{RALPH_PLANS_URL}")
  exit 1
end

if __FILE__ == $PROGRAM_NAME
  begin
    main
  rescue Interrupt
    exit 130
  end
end
