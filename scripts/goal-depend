#!/usr/bin/env ruby
# frozen_string_literal: true

#
# scripts/goal-depend - Manage goal dependencies
#
# Usage: goal-depend add <id> <depends_on_id>
#        goal-depend remove <id> <depends_on_id>
#        goal-depend list <id>
#
# Output: JSON {"ok": true, ...}
# Exit code: 0 on success, 1 on failure
#

require 'json'
require 'net/http'
require 'optparse'

RALPH_PLANS_BASE = 'http://127.0.0.1:8000/api/plans'

def main
  OptionParser.new do |opts|
    opts.banner = <<~HELP
      Usage: goal-depend add <id> <depends_on_id>
             goal-depend remove <id> <depends_on_id>
             goal-depend list <id>

      Manage dependencies between pipeline goals.

      Subcommands:
        add <id> <depends_on_id>    Add a dependency (POST)
        remove <id> <depends_on_id> Remove a dependency (DELETE)
        list <id>                   List dependency IDs (GET)

      What it does:
        add/remove: Only allowed when goal is in draft, queued, or stuck state.
        list: Returns the list of goal IDs this goal depends on.

      Output:
        JSON {"ok": true, ...}

      Examples:
        goal-depend add 42 7
        goal-depend remove 42 7
        goal-depend list 42
    HELP
  end.parse!

  subcommand = ARGV[0]

  unless %w[add remove list].include?(subcommand)
    puts JSON.generate(ok: false, error: 'subcommand must be add, remove, or list')
    exit 1
  end

  id = ARGV[1]&.to_i

  unless id && id > 0
    puts JSON.generate(ok: false, error: 'goal id is required')
    exit 1
  end

  base = RALPH_PLANS_BASE

  case subcommand
  when 'add'
    depends_on_id = ARGV[2]&.to_i
    unless depends_on_id && depends_on_id > 0
      puts JSON.generate(ok: false, error: 'depends_on_id is required')
      exit 1
    end
    uri = URI("#{base}/goals/#{id}/dependencies")
    req = Net::HTTP::Post.new(uri)
    req.content_type = 'application/json'
    req.body = JSON.generate(depends_on_id: depends_on_id)
    resp = Net::HTTP.start(uri.hostname, uri.port) { |http| http.request(req) }
    result = JSON.parse(resp.body)

  when 'remove'
    depends_on_id = ARGV[2]&.to_i
    unless depends_on_id && depends_on_id > 0
      puts JSON.generate(ok: false, error: 'depends_on_id is required')
      exit 1
    end
    uri = URI("#{base}/goals/#{id}/dependencies/#{depends_on_id}")
    req = Net::HTTP::Delete.new(uri)
    resp = Net::HTTP.start(uri.hostname, uri.port) { |http| http.request(req) }
    result = JSON.parse(resp.body)

  when 'list'
    uri = URI("#{base}/goals/#{id}/dependencies")
    req = Net::HTTP::Get.new(uri)
    resp = Net::HTTP.start(uri.hostname, uri.port) { |http| http.request(req) }
    result = JSON.parse(resp.body)
  end

  puts JSON.generate(result)
  exit(result['ok'] ? 0 : 1)
rescue Errno::ECONNREFUSED
  puts JSON.generate(ok: false, error: "cannot connect to ralph-plans at #{RALPH_PLANS_BASE}")
  exit 1
end

if __FILE__ == $PROGRAM_NAME
  begin
    main
  rescue Interrupt
    exit 130
  end
end
