#!/usr/bin/env ruby
# frozen_string_literal: true

#
# scripts/memory-create - Create a document in ralph-remembers
#
# Usage: echo "content" | memory-create [--agent AGENT] [--project PROJECT] [--title TITLE]
#
# Output: JSON {"ok": true, "id": ..., ...}
# Exit code: 0 on success, 1 on failure
#

require 'json'
require 'net/http'
require 'optparse'

RALPH_REMEMBERS_URL = ENV.fetch('RALPH_REMEMBERS_URL', 'http://ralph-remembers.localhost:8000')

def derive_org_repo_from_remote
  url = `git remote get-url origin 2>/dev/null`.strip
  return [nil, nil] if url.empty?

  # Local bare repo: /mnt/store/git/<org>/<repo>
  if url.start_with?('/')
    parts = url.split('/')
    return [parts[-2], parts[-1]] if parts.length >= 2
  end

  # GitHub SSH URL: git@github.com:<org>/<repo>.git
  if (m = url.match(/git@[^:]+:([^\/]+)\/(.+?)(?:\.git)?$/))
    return [m[1], m[2]]
  end

  # HTTPS URL: https://github.com/<org>/<repo>.git
  if (m = url.match(%r{https?://[^/]+/([^/]+)/(.+?)(?:\.git)?$}))
    return [m[1], m[2]]
  end

  [nil, nil]
end

def derive_defaults
  toplevel = `git rev-parse --show-toplevel 2>/dev/null`.strip
  if toplevel.empty?
    puts JSON.generate(ok: false, error: 'not in a git repository; --agent and --project are required')
    exit 1
  end

  org, repo = derive_org_repo_from_remote
  project = (org && repo) ? "#{org}/#{repo}" : nil
  ["#{ENV['USER']}@#{toplevel}", project]
end

def main
  agent = nil
  project = nil
  title = nil

  OptionParser.new do |opts|
    opts.banner = <<~HELP
      Usage: echo "content" | memory-create [--agent AGENT] [--project PROJECT] [--title TITLE]

      Create a document in ralph-remembers. Body is read from stdin.

      agent and project are auto-derived from the git repo when omitted.
      Use --agent/--project only to override the derived defaults.

      Flags:
        --agent AGENT       Agent identifier (optional; defaults to git repo root path)
        --project PROJECT   Project identifier (optional; defaults to org/repo from remote origin)
        --title TITLE       Human-readable title (optional; unique per agent+project scope)

      Output:
        JSON {"ok": true, "id": ..., "agent": ..., "project": ..., "title": ..., "body": ..., ...}

      Examples:
        echo "Session notes" | memory-create --title "Session 1"
        echo "Session notes" | memory-create --agent my-agent --title "Session 1"
        cat notes.md | memory-create --agent my-agent --project my-project --title "Architecture notes"
    HELP

    opts.on('--agent=AGENT', 'Agent identifier') { |a| agent = a }
    opts.on('--project=PROJECT', 'Project identifier') { |p| project = p }
    opts.on('--title=TITLE', 'Document title') { |t| title = t }
  end.parse!

  if agent.nil? || project.nil?
    derived_agent, derived_project = derive_defaults
    agent ||= derived_agent
    project ||= derived_project
  end

  if $stdin.tty?
    puts JSON.generate(ok: false, error: 'body must be provided on stdin')
    exit 1
  end

  body = $stdin.read.strip

  if body.empty?
    puts JSON.generate(ok: false, error: 'body is empty')
    exit 1
  end

  uri = URI("#{RALPH_REMEMBERS_URL}/documents")
  payload = { body: body }
  payload[:agent] = agent if agent
  payload[:project] = project if project
  payload[:title] = title if title

  resp = Net::HTTP.post(uri, JSON.generate(payload), 'Content-Type' => 'application/json')
  result = JSON.parse(resp.body)

  if resp.code.to_i >= 400
    puts JSON.generate(ok: false, error: result['error'] || 'request failed')
    exit 1
  end

  puts JSON.generate({ ok: true }.merge(result))
  exit 0
rescue Errno::ECONNREFUSED
  puts JSON.generate(ok: false, error: "cannot connect to ralph-remembers at #{RALPH_REMEMBERS_URL}")
  exit 1
end

if __FILE__ == $PROGRAM_NAME
  begin
    main
  rescue Interrupt
    exit 130
  end
end
