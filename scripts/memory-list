#!/usr/bin/env ruby
# frozen_string_literal: true

#
# scripts/memory-list - List documents in ralph-remembers
#
# Usage: memory-list [--agent AGENT] [--project PROJECT] [--title TITLE] [-q QUERY] [--limit N] [--offset N]
#
# Output: JSON {"ok": true, "items": [...], "total": N}
# Exit code: 0 on success, 1 on failure
#

require 'json'
require 'net/http'
require 'optparse'

RALPH_REMEMBERS_URL = ENV.fetch('RALPH_REMEMBERS_URL', 'http://ralph-remembers.localhost:8000')

def main
  agents = []
  projects = []
  title = nil
  query = nil
  limit = nil
  offset = nil

  OptionParser.new do |opts|
    opts.banner = <<~HELP
      Usage: memory-list [--agent AGENT] [--project PROJECT] [--title TITLE] [-q QUERY] [--limit N] [--offset N]

      List documents in ralph-remembers with optional filtering.

      Flags:
        --agent AGENT       Filter by agent (repeatable; matches any of the given values)
        --project PROJECT   Filter by project (repeatable; matches any of the given values)
        --title TITLE       Exact-match filter on title
        -q, --query QUERY   Full-text search query against document bodies
        --limit N           Maximum number of documents to return (default 50, max 100)
        --offset N          Number of documents to skip (default 0)

      Output:
        JSON {"ok": true, "items": [...], "total": N}

      Examples:
        memory-list
        memory-list --agent my-agent --project my-project
        memory-list --agent agent1 --agent agent2
        memory-list -q "architecture"
        memory-list --agent my-agent -q "migrations" --limit 10
        memory-list --title "Session Notes" --agent my-agent --project my-project
    HELP

    opts.on('--agent=AGENT', 'Filter by agent (repeatable)') { |a| agents << a }
    opts.on('--project=PROJECT', 'Filter by project (repeatable)') { |p| projects << p }
    opts.on('--title=TITLE', 'Exact-match filter on title') { |t| title = t }
    opts.on('-q', '--query=QUERY', 'Full-text search query') { |q| query = q }
    opts.on('--limit=N', Integer, 'Maximum number of results') { |n| limit = n }
    opts.on('--offset=N', Integer, 'Number of results to skip') { |n| offset = n }
  end.parse!

  uri = URI("#{RALPH_REMEMBERS_URL}/documents")
  params = []
  agents.each { |a| params << ['agent', a] }
  projects.each { |p| params << ['project', p] }
  params << ['title', title] if title
  params << ['q', query] if query
  params << ['limit', limit.to_s] if limit
  params << ['offset', offset.to_s] if offset
  uri.query = URI.encode_www_form(params) unless params.empty?

  resp = Net::HTTP.get_response(uri)
  result = JSON.parse(resp.body)

  if resp.code.to_i >= 400
    puts JSON.generate(ok: false, error: result['error'] || 'request failed')
    exit 1
  end

  puts JSON.generate({ ok: true }.merge(result))
  exit 0
rescue Errno::ECONNREFUSED
  puts JSON.generate(ok: false, error: "cannot connect to ralph-remembers at #{RALPH_REMEMBERS_URL}")
  exit 1
end

if __FILE__ == $PROGRAM_NAME
  begin
    main
  rescue Interrupt
    exit 130
  end
end
