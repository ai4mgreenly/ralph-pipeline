#!/usr/bin/env ruby
# frozen_string_literal: true

#
# scripts/memory-revision-get - Retrieve a specific document revision
#
# Usage: memory-revision-get <id> <rev>
#
# Output: JSON {"ok": true, "id": ..., "document_id": ..., "title": ..., "body": ..., ...}
# Exit code: 0 on success, 1 on failure
#

require 'json'
require 'net/http'
require 'optparse'

RALPH_REMEMBERS_URL = ENV.fetch('RALPH_REMEMBERS_URL', 'http://ralph-remembers.localhost:8000')

def main
  OptionParser.new do |opts|
    opts.banner = <<~HELP
      Usage: memory-revision-get <id> <rev>

      Retrieve a specific revision of a document with full body.
      Works for both active and soft-deleted documents.

      Arguments:
        id     Document UUID (required)
        rev    Revision UUID (required)

      Output:
        JSON {"ok": true, "id": ..., "document_id": ..., "title": ..., "body": ..., "created_at": ...}

      Examples:
        memory-revision-get a1b2c3d4-e5f6-7890-abcd-ef1234567890 rev1-uuid
        memory-revision-get a1b2c3d4-e5f6-7890-abcd-ef1234567890 rev1-uuid | jq .body
    HELP
  end.parse!

  id = ARGV[0]
  rev = ARGV[1]

  unless id && !id.empty?
    puts JSON.generate(ok: false, error: 'document id is required')
    exit 1
  end

  unless rev && !rev.empty?
    puts JSON.generate(ok: false, error: 'revision id is required')
    exit 1
  end

  uri = URI("#{RALPH_REMEMBERS_URL}/documents/#{id}/revisions/#{rev}")
  resp = Net::HTTP.get_response(uri)
  result = JSON.parse(resp.body)

  if resp.code.to_i >= 400
    puts JSON.generate(ok: false, error: result['error'] || 'request failed')
    exit 1
  end

  puts JSON.generate({ ok: true }.merge(result))
  exit 0
rescue Errno::ECONNREFUSED
  puts JSON.generate(ok: false, error: "cannot connect to ralph-remembers at #{RALPH_REMEMBERS_URL}")
  exit 1
end

if __FILE__ == $PROGRAM_NAME
  begin
    main
  rescue Interrupt
    exit 130
  end
end
