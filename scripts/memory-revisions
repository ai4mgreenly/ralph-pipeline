#!/usr/bin/env ruby
# frozen_string_literal: true

#
# scripts/memory-revisions - List revision metadata for a document
#
# Usage: memory-revisions <id>
#
# Output: JSON {"ok": true, "items": [...], "total": N}
# Exit code: 0 on success, 1 on failure
#

require 'json'
require 'net/http'
require 'optparse'

RALPH_REMEMBERS_URL = ENV.fetch('RALPH_REMEMBERS_URL', 'http://ralph-remembers.localhost:8000')

def main
  OptionParser.new do |opts|
    opts.banner = <<~HELP
      Usage: memory-revisions <id>

      List revision metadata for a document, ordered by timestamp descending.
      Works for both active and soft-deleted documents.

      Arguments:
        id    Document UUID (required)

      Output:
        JSON {"ok": true, "items": [{"id": ..., "created_at": ...}, ...], "total": N}

      Examples:
        memory-revisions a1b2c3d4-e5f6-7890-abcd-ef1234567890
        memory-revisions a1b2c3d4-e5f6-7890-abcd-ef1234567890 | jq '.items[0].id'
    HELP
  end.parse!

  id = ARGV[0]

  unless id && !id.empty?
    puts JSON.generate(ok: false, error: 'document id is required')
    exit 1
  end

  uri = URI("#{RALPH_REMEMBERS_URL}/documents/#{id}/revisions")
  resp = Net::HTTP.get_response(uri)
  result = JSON.parse(resp.body)

  if resp.code.to_i >= 400
    puts JSON.generate(ok: false, error: result['error'] || 'request failed')
    exit 1
  end

  puts JSON.generate({ ok: true }.merge(result))
  exit 0
rescue Errno::ECONNREFUSED
  puts JSON.generate(ok: false, error: "cannot connect to ralph-remembers at #{RALPH_REMEMBERS_URL}")
  exit 1
end

if __FILE__ == $PROGRAM_NAME
  begin
    main
  rescue Interrupt
    exit 130
  end
end
