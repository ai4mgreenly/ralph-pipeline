#!/usr/bin/env ruby
# frozen_string_literal: true

#
# scripts/memory-update - Update a document in ralph-remembers
#
# Usage: echo "new content" | memory-update <id> [--title TITLE]
#
# Output: JSON {"ok": true, "id": ..., ...}
# Exit code: 0 on success, 1 on failure
#

require 'json'
require 'net/http'
require 'optparse'

RALPH_REMEMBERS_URL = ENV.fetch('RALPH_REMEMBERS_URL', 'http://ralph-remembers.localhost:8000')

def main
  title = nil

  OptionParser.new do |opts|
    opts.banner = <<~HELP
      Usage: echo "new content" | memory-update <id> [--title TITLE]

      Update a document's body (and optionally title). Body is read from stdin.
      The current document state is snapshotted as a revision before the update.

      Arguments:
        id    Document UUID (required)

      Flags:
        --title TITLE   New title (optional; existing title is kept if omitted)

      Output:
        JSON {"ok": true, "id": ..., "agent": ..., "project": ..., "title": ..., "body": ..., ...}

      Examples:
        echo "Updated notes" | memory-update a1b2c3d4-e5f6-7890-abcd-ef1234567890
        cat notes.md | memory-update a1b2c3d4-e5f6-7890-abcd-ef1234567890 --title "New title"
    HELP

    opts.on('--title=TITLE', 'New document title') { |t| title = t }
  end.parse!

  id = ARGV[0]

  unless id && !id.empty?
    puts JSON.generate(ok: false, error: 'document id is required')
    exit 1
  end

  if $stdin.tty?
    puts JSON.generate(ok: false, error: 'body must be provided on stdin')
    exit 1
  end

  body = $stdin.read.strip

  if body.empty?
    puts JSON.generate(ok: false, error: 'body is empty')
    exit 1
  end

  uri = URI("#{RALPH_REMEMBERS_URL}/documents/#{id}")
  payload = { body: body }
  payload[:title] = title if title

  req = Net::HTTP::Put.new(uri, 'Content-Type' => 'application/json')
  req.body = JSON.generate(payload)
  resp = Net::HTTP.start(uri.hostname, uri.port) { |http| http.request(req) }
  result = JSON.parse(resp.body)

  if resp.code.to_i >= 400
    puts JSON.generate(ok: false, error: result['error'] || 'request failed')
    exit 1
  end

  puts JSON.generate({ ok: true }.merge(result))
  exit 0
rescue Errno::ECONNREFUSED
  puts JSON.generate(ok: false, error: "cannot connect to ralph-remembers at #{RALPH_REMEMBERS_URL}")
  exit 1
end

if __FILE__ == $PROGRAM_NAME
  begin
    main
  rescue Interrupt
    exit 130
  end
end
